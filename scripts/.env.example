# Copy to .env (in this same dir) and fill in. .env is .gitignored.

# Supabase — service role key has FULL DB access. Do not commit, do not share.
# Find at: Supabase dashboard → Project Settings → API → service_role secret
SUPABASE_URL=https://qyxdjdwgvwtrpnvfndnu.supabase.co
SUPABASE_SERVICE_KEY=

# YouTube Data API v3 — 10K quota/day free
# Get at: https://console.cloud.google.com/apis/credentials → Create API key
# Enable YouTube Data API v3 at: https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=

# Optional — seconds to wait between profile fetches (humanize / avoid bot detect)
PER_PROFILE_DELAY=5
